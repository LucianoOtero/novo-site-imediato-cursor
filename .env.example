# ==============================================================================
# .env.example — Imediato Seguros (Redesign)
# ==============================================================================
# Origem: ESPECIFICACAO v3.md (seção 45) + PLANO_IMPLEMENTACAO.md (seção 6, Issue P-04 / Issue 03A).
# Gerado na Issue P-04. Nenhum valor real. Não inventar dados.
#
# Regras obrigatórias:
# - NEXT_PUBLIC_* é exposto ao client (navegador) e NUNCA deve conter segredo.
# - Todas as demais variáveis são server-only (nunca prefixadas com NEXT_PUBLIC_).
# - Este arquivo é versionado com placeholders apenas.
# - .env.local (com valores reais) NUNCA deve ser commitado.
# - Validação real destas variáveis ocorre em runtime via lib/env.ts (Zod) — Issue 03A.
# - Em desenvolvimento/staging nenhuma variável é obrigatória (mocks); em
#   produção, lib/env.ts falha no boot se faltar uma variável obrigatória.
# - Itens marcados A_CONFIRMAR dependem de dados oficiais ainda pendentes
#   (ver docs/DADOS_OFICIAIS.md e a seção 5 do PLANO_IMPLEMENTACAO.md).
# ==============================================================================


# ------------------------------------------------------------------------------
# Ambiente da aplicação (Issue 03A) — OPCIONAL, não está na seção 45 original
# ------------------------------------------------------------------------------

# Sobrescreve a detecção automática de ambiente (development/staging/production).
# Se omitida, lib/env.ts usa VERCEL_ENV (Vercel expõe "production"/"preview"/
# "development" automaticamente — "preview" é tratado como "staging") e, fora
# da Vercel, cai para NODE_ENV. Normalmente não precisa ser definida manualmente.
# NEXT_PUBLIC_APP_ENV=development


# ------------------------------------------------------------------------------
# Site / URL canônica
# ------------------------------------------------------------------------------

# URL canônica do site em produção. Client-exposed (não-secreto). Obrigatória.
# Risco: Baixo.
NEXT_PUBLIC_SITE_URL=https://exemplo-placeholder.com.br


# ------------------------------------------------------------------------------
# Analytics / Tag Manager / Ads (ver docs/SEO_ANALYTICS_SPEC.md e lib/analytics.ts)
# ------------------------------------------------------------------------------

# ID do container GTM. Client-exposed. Obrigatória.
# A_CONFIRMAR: confirmar se o container atual (GTM-PD6J398, observado no site
# atual) será reaproveitado ou se um novo container será criado.
# Risco: Baixo.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ID da propriedade GA4. Client-exposed. Obrigatória.
# A_CONFIRMAR: depende de acesso à conta GA4 (ver seção 69 do plano).
# Risco: Baixo.
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ID de conversão do Google Ads. Configurado via GTM (não é NEXT_PUBLIC_ direto).
# A_CONFIRMAR: depende de acesso à conta Google Ads.
# Obrigatória. Risco: Baixo.
GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX

# Label de conversão do Google Ads. Configurado via GTM.
# A_CONFIRMAR: depende de acesso à conta Google Ads.
# Obrigatória. Risco: Baixo.
GOOGLE_ADS_CONVERSION_LABEL=xxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------------------------
# WhatsApp / Telefone (ver lib/whatsapp.ts, lib/company.ts)
# ------------------------------------------------------------------------------

# Número de WhatsApp oficial em formato E.164 (sem '+', só dígitos), usado em
# links wa.me. Client-exposed. Obrigatória.
# CONFIRMADO pelo cliente (2026-07-02): (11) 3230-1422, mesmo número do
# telefone principal (ver lib/company.ts e docs/DADOS_OFICIAIS.md). O valor
# abaixo continua sendo um placeholder — nunca commitar o número real aqui;
# usar .env.local para o valor de verdade.
# Risco: Baixo.
NEXT_PUBLIC_WHATSAPP_NUMBER=5511900000000

# Telefone principal exibido (formato E.164), usado em links tel:. Client-exposed.
# Obrigatória. A_CONFIRMAR (telefone principal ainda não confirmado).
# Risco: Baixo.
NEXT_PUBLIC_CONTACT_PHONE=+5511000000000


# ------------------------------------------------------------------------------
# Captura de leads — arquitetura "Firebase-only" (ver /api/lead,
# lib/leads/firebase-backup.ts, firebase/functions/index.js).
#
# Desde 2026-07-13, o site NÃO chama mais EspoCRM/Octadesk direto — só
# grava no Firebase Realtime Database, e a Cloud Function `deliverLead`
# (projeto Firebase separado, fora do Vercel) faz a entrega real, usando
# seus PRÓPRIOS secrets (ESPOCRM_DEV_URL/ESPOCRM_PROD_URL/OCTADESK_URL,
# configurados via `firebase functions:secrets:set` — ver
# firebase/README.md). As antigas LEAD_ESPOCRM_WEBHOOK_URL_DEV/_PROD e
# LEAD_OCTADESK_WEBHOOK_URL não são mais usadas pelo site — mantidas fora
# deste arquivo (removidas). Réplica fiel do modo "Firebase-Only" que já
# é a configuração ativa confirmada no site legado
# (`window.MODAL_FIREBASE_ONLY = true`) — ver
# docs/ANALISE_ESPOCRM_OCTADESK_FIREBASE_CLOUDRUN.md e
# docs/ARQUITETURA_LEADS_FIREBASE_CLOUD_FUNCTION.md.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Backup de leads no Firebase Realtime Database (gatilho da Cloud
# Function de entrega — projeto 2026-07-12/13, ver
# docs/ARQUITETURA_LEADS_FIREBASE_CLOUD_FUNCTION.md).
# Projeto Firebase dedicado ao site novo (distinto do `leads-imediato-
# seguros` do legado). Opcionais: sem as 4 variáveis abaixo, o backup roda
# em modo mock (só log) — nunca bloqueia o envio do lead, mas também
# nunca entrega a EspoCRM/Octadesk (sem gravação, a Cloud Function nunca
# é disparada).
# Server-only. Risco: Baixo (funcionalidade auxiliar, não bloqueante).
# ------------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# ------------------------------------------------------------------------------
# Validação em tempo real: telefone (APILayer) e e-mail (SafetyMails)
# (projeto 2026-07-13, ver app/api/validate/*, lib/validation/*).
# Credenciais reaproveitadas do site legado (decisão do cliente, 2026-07-13).
# Chamadas feitas server-side (nunca expostas ao navegador — diferente do
# legado). Sem as variáveis, os proxies rodam em modo mock (`ok: true`,
# nunca bloqueia). SafetyMails: achado 2026-07-13 — as 2 variantes
# conhecidas não respondem hoje (mesmo com credenciais reais, testadas
# diretamente); implementado best-effort mesmo assim (nunca bloqueia o
# usuário se a chamada falhar). Ver lib/validation/email-safetymails.ts.
# Server-only. Opcionais. Risco: Médio (chaves de terceiro, mas nunca
# expostas ao client).
# ------------------------------------------------------------------------------
APILAYER_KEY=
APILAYER_BASE_URL=https://apilayer.net
SAFETY_TICKET=
SAFETY_API_KEY=
SAFETYMAILS_BASE_DOMAIN=safetymails.com

# ------------------------------------------------------------------------------
# Validação em tempo real: CEP (ViaCEP) e Placa (proxy Cloud Run "Placa
# Fipe") — projeto 2026-07-14, ver app/api/validate/cep e
# app/api/validate/placa, lib/validation/cep-viacep.ts e
# lib/validation/placa-fipe.ts. Réplica de `validarCepViaCep`/
# `validarPlacaApi` (FooterCodeSiteDefinitivoCompleto.js) e
# `validateCEP`/`validatePlaca` (webflow_injection_limpo.js).
# ViaCEP é uma API pública (sem chave) — VIACEP_BASE_URL é só um
# override opcional (padrão já funciona sem configurar nada). A Placa
# Fipe usa o mesmo padrão dev/prod do EspoCRM: PLACA_VALIDATE_URL_PROD
# em produção, PLACA_VALIDATE_URL_DEV nos demais ambientes. Sem a URL
# correspondente, o proxy roda em modo mock (`ok: true`, nunca bloqueia).
# Server-only. Opcionais. Risco: Baixo (funcionalidade auxiliar, best-effort).
# ------------------------------------------------------------------------------
VIACEP_BASE_URL=https://viacep.com.br
PLACA_VALIDATE_URL_DEV=
PLACA_VALIDATE_URL_PROD=

# E-mail de fallback — legado do fluxo de entrega direta (removido em
# 2026-07-13, ver arquitetura "Firebase-only" acima). Opcional agora
# (nenhum código chama isso hoje); mantido só para eventual reintrodução
# futura de um alerta por e-mail.
# Server-only. Opcional. Risco: Médio.
LEAD_FALLBACK_EMAIL=leads@exemplo-placeholder.com.br

# Chave de API do provedor de e-mail (ex.: Resend) usado no fallback.
# Server-only. Opcional. NUNCA expor ao client.
# Risco: Alto.
EMAIL_API_KEY=re_placeholder_never_commit_real_value

# --- Legado/opcional (pré-2026-07-03) ---
# Destino genérico inventado antes de o CRM real (EspoCRM) ser confirmado.
# Não é mais obrigatório — mantido apenas para compatibilidade, caso um
# 3º destino de webhook genérico seja necessário no futuro.
# Risco: Médio.
LEAD_WEBHOOK_URL=https://exemplo-placeholder.com/webhook/lead
LEAD_WEBHOOK_SECRET=whsec_placeholder_never_commit_real_value
CRM_API_URL=https://exemplo-placeholder.com/api/v1
CRM_API_KEY=crm_placeholder_never_commit_real_value


# ------------------------------------------------------------------------------
# RPA — cotação automatizada (ver lib/rpa.ts)
# ------------------------------------------------------------------------------

# Habilita o disparo do RPA (cotação automatizada) após o envio do lead.
# CONFIRMADO real (docs/WEBFLOW_CUSTOM_CODE_DEV.md) — desabilitado por padrão,
# mesmo comportamento do ambiente DEV do Webflow (`data-rpa-enabled` lá é
# "true", mas optamos por manter "false" por padrão até validar em staging).
# Client-exposed (chamada é feita direto do navegador, como no site legado).
# Opcional. Risco: Baixo.
NEXT_PUBLIC_RPA_ENABLED=false

# URL base da API de RPA. Mesma URL confirmada em todos os ambientes (não há
# variante de dev/prod separada). Client-exposed. Opcional (tem default no
# código). Risco: Baixo.
NEXT_PUBLIC_RPA_API_BASE_URL=https://rpaimediatoseguros.com.br


# ------------------------------------------------------------------------------
# PH3A — enriquecimento de CPF (ver app/api/lead/route.ts)
# ------------------------------------------------------------------------------

# Habilita a consulta de enriquecimento de CPF (sexo/data de nascimento/estado
# civil) via PH3A, feita de forma server-side e não-bloqueante após o envio
# do lead. Desabilitado por padrão — mesmo comportamento do ambiente DEV do
# Webflow (`data-validar-ph3a="false"`).
# Server-only. Opcional. Risco: Baixo.
PH3A_ENRICHMENT_ENABLED=false

# URL do proxy Cloud Run que valida/enriquece CPF (mesmo proxy usado pelo site
# legado). URLs reais confirmadas lendo o config_env.js do site legado:
#   Dev:  https://cpf-validate-dev-6r55ex3u6q-rj.a.run.app/
#   Prod: https://cpf-validate-prod-br2qvvxwhq-rj.a.run.app/
# Server-only. Opcional (só usada se PH3A_ENRICHMENT_ENABLED=true).
# Risco: Médio.
CPF_VALIDATE_PROXY_URL=https://cpf-validate-dev-6r55ex3u6q-rj.a.run.app/


# ------------------------------------------------------------------------------
# Testimonials — avaliações reais via Google Places API (ver lib/google-reviews.ts)
# ------------------------------------------------------------------------------

# Chave de API de um projeto Google Cloud com "Places API (New)" habilitada e
# faturamento ativo. CONFIRMADO/ATIVO (2026-07-08) — cliente criou a chave no
# projeto `leads-imediato-seguros` (mesmo projeto do Firebase de backup de
# leads), restrita apenas à Places API (New). Sem esta variável (ex.: outros
# ambientes ainda não configurados), usa 12 avaliações reais extraídas do site
# atual como fallback (não são dados fictícios).
# Server-only. Obrigatória para a integração real (opcional para o projeto
# rodar — cai no fallback). NUNCA expor ao client. Risco: Médio.
GOOGLE_PLACES_API_KEY=AIzaSy_placeholder_never_commit_real_value

# ATENÇÃO: distinto de company.google.placeId (lib/company.ts), que está no
# formato CID (0x...:0x..., usado em URLs do Google Maps). A Places API exige
# o formato padrão de Place ID (geralmente iniciado em "ChIJ"). CONFIRMADO
# (2026-07-08) — encontrado via chamada real ao endpoint places:searchText,
# buscando "Imediato Seguros" + endereço confirmado; retornou nome, endereço
# e nota batendo com os dados já confirmados em lib/company.ts.
# Server-only. Opcional (tem fallback). Risco: Baixo.
GOOGLE_PLACE_ID=ChIJ_placeholder_confirmar_formato_correto


# ------------------------------------------------------------------------------
# Segurança e anti-spam de /api/lead (ver ESPECIFICACAO v3.md seção 51)
# ------------------------------------------------------------------------------

# Salt usado para gerar hash SHA-256 do IP (nunca armazenar IP em claro).
# Server-only. Obrigatória. Gerar um valor aleatório forte (ex.: 32 bytes) e
# NUNCA commitar o valor real. NUNCA expor ao client.
# Risco: Alto.
IP_HASH_SALT=replace-with-random-32-byte-value

# Site key do Cloudflare Turnstile (anti-spam do formulário). Client-exposed.
# Obrigatória. A_CONFIRMAR (depende de provisionamento do serviço Turnstile).
# Risco: Baixo.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000000000

# Secret key do Cloudflare Turnstile, usado na verificação server-side.
# Server-only. Obrigatória. NUNCA expor ao client.
# Risco: Alto.
TURNSTILE_SECRET_KEY=0x0000000000000000000000_secret_placeholder


# ------------------------------------------------------------------------------
# Observabilidade (ver ESPECIFICACAO v3.md seção 51)
# ------------------------------------------------------------------------------

# DSN do Sentry para captura de erros no servidor. Server-only. Opcional.
# Risco: Baixo.
SENTRY_DSN=https://exemplo-placeholder@o000000.ingest.sentry.io/0000000

# DSN do Sentry exposto ao client (para captura de erros no navegador).
# Client-exposed. Opcional.
# Risco: Baixo.
NEXT_PUBLIC_SENTRY_DSN=https://exemplo-placeholder@o000000.ingest.sentry.io/0000000


# ------------------------------------------------------------------------------
# Persistência (ver /api/lead — DB é a fonte da verdade)
# ------------------------------------------------------------------------------

# URL de conexão do banco de dados (persistência de leads). Server-only.
# Obrigatória. A_CONFIRMAR (depende de provisionamento do banco — ver seção 69
# do plano, "Banco de dados").
# Risco: Alto.
DATABASE_URL=postgres://usuario:senha@host:5432/banco_placeholder


# ------------------------------------------------------------------------------
# Nota sobre Cloudinary (ADR-0009 — status: Proposta, ainda NÃO aceita)
# ------------------------------------------------------------------------------
# A ESPECIFICACAO v3.md (seção 45) não define uma variável de ambiente para
# Cloudinary. A ADR-0009 (docs/DECISIONS.md) ainda está com status "Proposta".
# Nenhuma variável de Cloudinary foi adicionada aqui para não inventar um nome
# de variável não definido pela fonte canônica. Caso o uso de Cloudinary seja
# aceito (ADR-0009 -> "Aceita") e uma variável real seja definida, ela deverá
# ser adicionada aqui como NEXT_PUBLIC_CLOUDINARY_* (não-secreta) ou
# CLOUDINARY_API_SECRET (server-only, se aplicável), seguindo o mesmo padrão
# deste arquivo — nunca com valor real, e nunca segredo em NEXT_PUBLIC_*.
